{
  "appTitle": "NetWatch Lite Wallboard",
  "rotationEnabled": true,
  "rotationSeconds": 20,
  "defaultLayout": 4,
  "panels": [
    {
      "name": "SSLAW Overview",
      "url": "https://ny43rcsi.linux.us.ups.com/ssla/overview.php",
      "refreshSeconds": 10,
      "monitoring": {
        "enabled": true,
        "pollSeconds": 3,
        "soundEnabled": true,
        "repeatSoundSeconds": 5,
        "rules": [
          {
            "name": "PLC Alarm Modal",
            "type": "domText",
            "selector": "#divAlarm.on .alarmTitle",
            "contains": "PLC Alarm Detected",
            "severity": "critical",
            "detailsSelector": "#divAlarm.on .alarmDiv"
          },
          {
            "name": "Health Red Indicator",
            "type": "exists",
            "selector": ".overviewHealth .ledRED, #divHealth .ledRED",
            "severity": "warning",
            "detailsSelector": ".overviewHealth .ledRED, #divHealth .ledRED",
            "soundEnabled": false
          }
        ]
      }
    },
    {
      "name": "Application Status",
      "url": "https://dotnet.microsoft.com/",
      "refreshSeconds": 12
    },
    {
      "name": "Cloud Dashboard",
      "url": "https://azure.microsoft.com/",
      "refreshSeconds": 14
    },
    {
      "name": "Team Portal",
      "url": "https://github.com/",
      "refreshSeconds": 16
    },
    {
      "name": "Incident Queue",
      "url": "https://example.org/",
      "refreshSeconds": 18
    },
    {
      "name": "Service Metrics",
      "url": "https://example.net/",
      "refreshSeconds": 20
    },
    {
      "name": "Network Map",
      "url": "https://www.iana.org/domains/reserved",
      "refreshSeconds": 22
    },
    {
      "name": "Change Calendar",
      "url": "https://www.rfc-editor.org/",
      "refreshSeconds": 24
    }
  ]
}
